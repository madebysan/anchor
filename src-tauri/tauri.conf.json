{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Inline MD",
  "version": "0.1.0",
  "identifier": "com.santiagoalonso.inline-md",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Inline MD",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "AI instructions anchored to your text.",
    "longDescription": "Inline MD is a desktop markdown editor where AI instructions are anchored to passages. Uses Claude Code locally — no API keys.",
    "macOS": {
      "signingIdentity": "Developer ID Application: Santiago Alonso Alexandre (QAMM2A6WRQ)",
      "providerShortName": "QAMM2A6WRQ"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
